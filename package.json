{
  "name": "nextjs-cors",
  "version": "0.0.0",
  "private": true,
  "description": "Nextjs-Cors is a node.js package to provide a middleware that can be used to enable CORS with various options in nextjs applications.",
  "keywords": [
    "nextjs-cors",
    "express-cors",
    "nextjs-express-cors",
    "next-cors",
    "cors-server",
    "cors"
  ],
  "homepage": "https://github.com/yonycalsin/nextjs-cors#readme",
  "bugs": {
    "url": "https://github.com/yonycalsin/nextjs-cors/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yonycalsin/nextjs-cors.git"
  },
  "license": "MIT",
  "author": "Yony Calsin",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "pnpm run prettier -- --write",
    "lint": "echo \"Hello Linter\"",
    "lint:es": "eslint packages",
    "lint:pretty": "pnpm run prettier -- --list-different",
    "lint:ts": "tsc --noEmit",
    "prettier": "prettier --ignore-path .gitignore \"**/*.{ts,tsx,json,md}\"",
    "semantic-release": "semantic-release"
  },
  "husky": {
    "hooks": {
      "pre-commit": "tsdx lint",
      "pre-push": "pnpm run typecheck"
    }
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "husky": "6.0.0",
    "lint-staged": "10.5.4",
    "prettier": "2.0.5",
    "prettier-plugin-organize-imports": "2.0.0",
    "rimraf": "3.0.2",
    "semantic-release": "18.0.0",
    "turbo": "1.6.3"
  },
  "packageManager": "pnpm@7.14.2",
  "volta": {
    "node": "14.17.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
